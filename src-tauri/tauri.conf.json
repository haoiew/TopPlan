{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TopPlan",
  "version": "0.1.0",
  "identifier": "com.topplan.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "TopPlan",
        "label": "main",
        "width": 420,
        "height": 640,
        "x": 0,
        "y": 0,
        "resizable": true,
        "decorations": false,
        "alwaysOnTop": true,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": []
  }
}

